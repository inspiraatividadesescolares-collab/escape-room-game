<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#1a1a1a">
    <title>O Casarão Abandonado - Escape Room</title>
    <link rel="manifest" href="manifest.json">
    <link rel="icon" type="image/png" href="icon-192.png">
    <link rel="apple-touch-icon" href="icon-192.png">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: #0a0a0a;
            color: #fff;
            overflow: hidden;
            height: 100vh;
        }

        .container {
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #1a1a1a;
        }

        .fullscreen-btn {
            position: fixed;
            top: 10px;
            right: 10px;
            z-index: 1000;
            padding: 10px 15px;
            background: rgba(255, 100, 50, 0.8);
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
        }

        .fullscreen-btn:hover {
            background: rgba(255, 100, 50, 1);
        }

        /* TELA INICIAL */
        .screen {
            width: 100%;
            height: 100%;
            display: none;
            position: absolute;
        }

        .screen.active {
            display: flex;
        }

        #tela-inicial {
            background: linear-gradient(135deg, #2d1b2e 0%, #1a0f1a 100%);
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .home-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            width: 90%;
            height: 90%;
            gap: 30px;
            align-items: center;
        }

        .home-text {
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 30px;
        }

        .home-text h1 {
            font-size: 48px;
            margin-bottom: 20px;
            color: #ff6432;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
            font-weight: bold;
        }

        .home-text p {
            font-size: 24px;
            margin: 15px 0;
            color: #ffd700;
            font-weight: bold;
        }

        .home-text .subtitle {
            font-size: 18px;
            color: #aaa;
            margin-top: 20px;
            font-style: italic;
        }

        .home-image {
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            overflow: hidden;
        }

        .home-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .play-btn {
            margin-top: 40px;
            padding: 15px 50px;
            font-size: 24px;
            background: linear-gradient(135deg, #ff6432, #ff8c42);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 100, 50, 0.4);
        }

        .play-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 20px rgba(255, 100, 50, 0.6);
        }

        .play-btn:active {
            transform: scale(0.98);
        }

        /* TELAS DE NARRATIVA */
        .narrative-screen {
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            position: relative;
        }

        .narrative-overlay {
            background: rgba(0, 0, 0, 0.6);
            padding: 40px;
            border-radius: 10px;
            margin: 20px;
            position: relative;
            z-index: 100;
        }

        .narrative-text {
            font-size: 28px;
            line-height: 1.6;
            color: #fff;
            margin-bottom: 30px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
            font-weight: bold;
        }

        .continue-btn {
            padding: 12px 40px;
            font-size: 18px;
            background: linear-gradient(135deg, #ff6432, #ff8c42);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            align-self: flex-end;
            transition: all 0.3s ease;
        }

        .continue-btn:hover {
            transform: scale(1.05);
        }

        /* TELAS DE QUESTÃO */
        .question-screen {
            background: linear-gradient(135deg, #2d1b2e 0%, #1a0f1a 100%);
            flex-direction: column;
            justify-content: space-between;
            padding: 30px;
        }

        .question-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .question-info {
            display: flex;
            gap: 30px;
            font-size: 20px;
            font-weight: bold;
        }

        .question-info span {
            color: #ff6432;
        }

        .timer {
            font-size: 36px;
            font-weight: bold;
            color: #ffd700;
            background: rgba(0, 0, 0, 0.5);
            padding: 10px 20px;
            border-radius: 8px;
            min-width: 120px;
            text-align: center;
        }

        .timer.warning {
            color: #ff4444;
            animation: pulse 0.5s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .question-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            margin: 20px 0;
        }

        .question-text {
            font-size: 26px;
            margin-bottom: 30px;
            color: #fff;
            line-height: 1.6;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
        }

        .answers-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .answer-btn {
            padding: 20px;
            font-size: 18px;
            background: rgba(255, 100, 50, 0.2);
            color: #fff;
            border: 2px solid #ff6432;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
            position: relative;
        }

        .answer-btn:hover:not(:disabled) {
            background: rgba(255, 100, 50, 0.4);
            transform: scale(1.05);
        }

        .answer-btn:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

        .answer-btn.correct {
            background: rgba(100, 200, 100, 0.5);
            border-color: #64c864;
            animation: correctAnswer 0.5s ease;
        }

        .answer-btn.incorrect {
            background: rgba(255, 100, 100, 0.5);
            border-color: #ff6464;
            animation: incorrectAnswer 0.5s ease;
        }

        @keyframes correctAnswer {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes incorrectAnswer {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }

        /* TELA DE TEMPO ESGOTADO */
        .timeout-screen {
            background: linear-gradient(135deg, #4a0000 0%, #1a0000 100%);
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .timeout-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            width: 90%;
            height: 80%;
            align-items: center;
        }

        .timeout-text {
            text-align: center;
        }

        .timeout-text h1 {
            font-size: 48px;
            color: #ff4444;
            margin-bottom: 20px;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
        }

        .timeout-text p {
            font-size: 24px;
            color: #fff;
            margin: 10px 0;
        }

        .timeout-image {
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            overflow: hidden;
            height: 100%;
        }

        .timeout-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* TELAS DE RESPOSTA */
        .result-screen {
            background: linear-gradient(135deg, #2d1b2e 0%, #1a0f1a 100%);
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .result-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            width: 90%;
            height: 80%;
            align-items: center;
        }

        .result-text {
            text-align: center;
        }

        .result-text h1 {
            font-size: 44px;
            margin-bottom: 20px;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
        }

        .result-text p {
            font-size: 20px;
            color: #fff;
            margin: 10px 0;
            line-height: 1.6;
        }

        #correct-result h1 {
            color: #64c864;
        }

        #incorrect-result h1 {
            color: #ff6464;
        }

        .result-image {
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            overflow: hidden;
            height: 100%;
        }

        .result-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .next-btn {
            margin-top: 20px;
            padding: 12px 40px;
            font-size: 18px;
            background: linear-gradient(135deg, #ff6432, #ff8c42);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .next-btn:hover {
            transform: scale(1.05);
        }

        /* TELA DE DESAFIO FINAL */
        #final-challenge {
            background: linear-gradient(135deg, #1a3a1a 0%, #0f2a0f 100%);
        }

        .challenge-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .challenge-header h1 {
            font-size: 36px;
            color: #ffd700;
            margin-bottom: 10px;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
        }

        .challenge-header p {
            font-size: 20px;
            color: #fff;
        }

        .challenge-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            align-items: center;
            flex: 1;
        }

        .challenge-input {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .password-boxes {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 20px;
        }

        .password-box {
            width: 60px;
            height: 80px;
            background: rgba(255, 215, 0, 0.2);
            border: 3px solid #ffd700;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: bold;
            color: #fff;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .password-box:hover:not([disabled]) {
            background: rgba(255, 215, 0, 0.4);
            transform: scale(1.05);
        }

        .password-box[disabled] {
            cursor: not-allowed;
            opacity: 0.6;
        }

        .password-input-popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.95);
            padding: 30px;
            border-radius: 10px;
            border: 3px solid #ffd700;
            z-index: 2000;
            display: none;
            flex-direction: column;
            gap: 20px;
            min-width: 300px;
        }

        .password-input-popup.active {
            display: flex;
        }

        .password-input-popup input {
            padding: 15px;
            font-size: 20px;
            background: rgba(255, 215, 0, 0.1);
            color: #ffd700;
            border: 2px solid #ffd700;
            border-radius: 5px;
            text-align: center;
            text-transform: uppercase;
        }

        .password-input-popup input::placeholder {
            color: rgba(255, 215, 0, 0.5);
        }

        .input-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .confirm-btn {
            padding: 10px 20px;
            background: #64c864;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        .confirm-btn:hover {
            background: #80d880;
        }

        .cancel-btn {
            padding: 10px 20px;
            background: #ff6464;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        .cancel-btn:hover {
            background: #ff8080;
        }

        .challenge-submit {
            padding: 15px 40px;
            font-size: 20px;
            background: linear-gradient(135deg, #ffd700, #ffed4e);
            color: #000;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .challenge-submit:hover {
            transform: scale(1.05);
        }

        .challenge-image {
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            overflow: hidden;
            height: 100%;
        }

        .challenge-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* TELA DE VITÓRIA */
        #victory-screen {
            background: linear-gradient(135deg, #1a4a1a 0%, #0f3a0f 100%);
        }

        .victory-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            width: 90%;
            height: 80%;
            align-items: center;
        }

        .victory-text {
            text-align: center;
        }

        .victory-text h1 {
            font-size: 48px;
            color: #64c864;
            margin-bottom: 20px;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
            animation: celebrate 0.5s ease;
        }

        @keyframes celebrate {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .victory-text p {
            font-size: 24px;
            color: #ffd700;
            margin: 15px 0;
            font-weight: bold;
        }

        .victory-image {
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            overflow: hidden;
            height: 100%;
        }

        .victory-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* TELA DE DERROTA */
        #defeat-screen {
            background: linear-gradient(135deg, #4a1a1a 0%, #2a0a0a 100%);
        }

        .defeat-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            width: 90%;
            height: 80%;
            align-items: center;
        }

        .defeat-text {
            text-align: center;
        }

        .defeat-text h1 {
            font-size: 48px;
            color: #ff6464;
            margin-bottom: 20px;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
        }

        .defeat-text p {
            font-size: 24px;
            color: #fff;
            margin: 15px 0;
        }

        .defeat-image {
            display: flex;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
            overflow: hidden;
            height: 100%;
        }

        .defeat-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* TELA DE PISTAS */
        .hints-screen {
            background: linear-gradient(135deg, #2d2d1a 0%, #1a1a0f 100%);
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .hints-container {
            background: rgba(0, 0, 0, 0.5);
            padding: 40px;
            border-radius: 15px;
            border: 3px solid #ffd700;
            max-width: 80%;
        }

        .hints-container h1 {
            font-size: 36px;
            color: #ffd700;
            margin-bottom: 30px;
            text-align: center;
            font-weight: bold;
        }

        .hints-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
            margin-bottom: 30px;
        }

        .hint-item {
            padding: 20px;
            background: rgba(255, 215, 0, 0.1);
            border-left: 5px solid #ffd700;
            border-radius: 5px;
            font-size: 20px;
            color: #ffd700;
            font-weight: bold;
            line-height: 1.6;
        }

        .hint-item.locked {
            opacity: 0.5;
            color: #999;
            border-left-color: #666;
        }

        .close-hints-btn {
            padding: 15px 40px;
            font-size: 18px;
            background: linear-gradient(135deg, #ff6432, #ff8c42);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            align-self: center;
        }

        .close-hints-btn:hover {
            transform: scale(1.05);
        }

        /* RESPONSIVO */
        @media (max-aspect-ratio: 7/15) {
            .home-container,
            .timeout-content,
            .result-content,
            .challenge-content,
            .victory-content,
            .defeat-content {
                grid-template-columns: 1fr;
            }

            .home-text h1 {
                font-size: 32px;
            }

            .question-text {
                font-size: 20px;
            }

            .answers-container {
                grid-template-columns: 1fr;
            }
        }

        /* DICAS VISUAIS */
        .hint-badge {
            position: fixed;
            top: 10px;
            left: 10px;
            background: #ffd700;
            color: #000;
            padding: 10px 15px;
            border-radius: 20px;
            font-weight: bold;
            cursor: pointer;
            z-index: 500;
            transition: all 0.3s ease;
        }

        .hint-badge:hover {
            transform: scale(1.1);
        }

        .level-badge {
            background: rgba(255, 100, 50, 0.8);
            color: white;
            padding: 5px 12px;
            border-radius: 5px;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <button class="fullscreen-btn" id="fullscreenBtn">⛶ Tela Cheia</button>

    <div class="container">
        <!-- TELA INICIAL -->
        <div id="tela-inicial" class="screen active">
            <div class="home-container">
                <div class="home-text">
                    <h1>🏚️ ESCAPE ROOM</h1>
                    <p>Raciocínio Lógico</p>
                    <h2 style="font-size: 32px; color: #ff6432; margin: 20px 0;">A Casa Abandonada</h2>
                    <p class="subtitle">Criado por Edneia Angélica Gomes</p>
                    <button class="play-btn" onclick="startNarrative()">▶ JOGAR</button>
                </div>
                <div class="home-image">
                    <img src="assets/images/tela-inicial.png" alt="Casa Abandonada">
                </div>
            </div>
        </div>

        <!-- TELAS DE NARRATIVA -->
        <div id="narrativa-1" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">Era uma noite quente de verão. Os amigos: Luisa, Bruno, Matheus e Isabela estavam jogando bola na rua.</div>
                <button class="continue-btn" onclick="nextScreen()">Continuar ▶</button>
            </div>
        </div>

        <div id="narrativa-2" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">A bola caiu em um casarão abandonado que ficava na esquina.</div>
                <button class="continue-btn" onclick="nextScreen()">Continuar ▶</button>
            </div>
        </div>

        <div id="narrativa-3" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">Mesmo com medo, os 4 amigos resolveram ir até lá para recuperar a bola.</div>
                <button class="continue-btn" onclick="nextScreen()">Continuar ▶</button>
            </div>
        </div>

        <div id="narrativa-4" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">Quando eles entraram no casarão, a porta se fechou sozinha.</div>
                <button class="continue-btn" onclick="nextScreen()">Continuar ▶</button>
            </div>
        </div>

        <div id="narrativa-5" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">As crianças tentaram abrir, mas não conseguiram.</div>
                <button class="continue-btn" onclick="nextScreen()">Continuar ▶</button>
            </div>
        </div>

        <div id="narrativa-6" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">De repente, uma vela se acendeu e, debaixo dela, eles encontraram um bilhete:</div>
                <button class="continue-btn" onclick="nextScreen()">Continuar ▶</button>
            </div>
        </div>

        <div id="narrativa-7" class="screen narrative-screen">
            <div class="narrative-overlay">
                <div class="narrative-text">"Vocês entraram na minha casa sem ser convidados e agora estão presos. Só os deixarei sair, se resolverem os meus desafios de matemática"</div>
                <button class="continue-btn" onclick="startQuestions()">Começar Desafios ▶</button>
            </div>
        </div>

        <!-- TELAS DE QUESTÕES -->
        <div id="question-screen" class="screen question-screen">
            <div class="question-header">
                <div class="question-info">
                    <span>Questão <span id="current-question">1</span>/25</span>
                    <span>Nível: <span id="current-level" class="level-badge">Fácil</span></span>
                </div>
                <div class="timer" id="timer">1:00</div>
            </div>

            <div class="question-container">
                <div class="question-text" id="question-text"></div>
                <div class="answers-container" id="answers-container"></div>
            </div>
        </div>

        <!-- TELA DE TEMPO ESGOTADO -->
        <div id="timeout-screen" class="screen timeout-screen">
            <div class="timeout-content">
                <div class="timeout-text">
                    <h1>⏰ TEMPO ESGOTADO!</h1>
                    <p>Você não conseguiu responder a tempo.</p>
                    <p>Tente novamente na próxima questão.</p>
                </div>
                <div class="timeout-image">
                    <img src="assets/images/tempo-esgotado.png" alt="Tempo Esgotado">
                </div>
            </div>
        </div>

        <!-- TELA DE RESPOSTA CORRETA -->
        <div id="correct-result" class="screen result-screen">
            <div class="result-content">
                <div class="result-text">
                    <h1>✓ RESPOSTA CORRETA!</h1>
                    <p>Parabéns! Você acertou essa questão.</p>
                    <button class="next-btn" onclick="nextQuestion()">Próxima Questão ▶</button>
                </div>
                <div class="result-image">
                    <img src="assets/images/acerto.png" alt="Acerto">
                </div>
            </div>
        </div>

        <!-- TELA DE RESPOSTA ERRADA -->
        <div id="incorrect-result" class="screen result-screen">
            <div class="result-content">
                <div class="result-text">
                    <h1>✗ RESPOSTA INCORRETA!</h1>
                    <p>Infelizmente você errou. A resposta correta era:</p>
                    <p id="correct-answer" style="color: #64c864; font-size: 28px;"></p>
                    <button class="next-btn" onclick="nextQuestion()">Próxima Questão ▶</button>
                </div>
                <div class="result-image">
                    <img src="assets/images/erro.png" alt="Erro">
                </div>
            </div>
        </div>

        <!-- TELA DE PISTAS -->
        <div id="hints-screen" class="screen hints-screen">
            <div class="hints-container">
                <h1>🔓 PISTAS DESBLOQUEADAS</h1>
                <div class="hints-list" id="hints-list"></div>
                <button class="close-hints-btn" onclick="closeHints()">Fechar</button>
            </div>
        </div>

        <!-- TELA DE DESAFIO FINAL -->
        <div id="final-challenge" class="screen result-screen">
            <div class="challenge-header">
                <h1>🔐 DESAFIO FINAL</h1>
                <p>Descubra a senha para sair da casa!</p>
            </div>
            <div class="challenge-content">
                <div class="challenge-input">
                    <p style="color: #ffd700; font-size: 20px; text-align: center;">Clique nas caixinhas e insira as letras:</p>
                    <div class="password-boxes" id="password-boxes"></div>
                    <button class="challenge-submit" onclick="submitPassword()">Abrir Porta 🔓</button>
                </div>
                <div class="challenge-image">
                    <img src="assets/images/desafio-final.png" alt="Desafio Final">
                </div>
            </div>
        </div>

        <!-- TELA DE VITÓRIA -->
        <div id="victory-screen" class="screen result-screen">
            <div class="victory-content">
                <div class="victory-text">
                    <h1>🎉 PARABÉNS!</h1>
                    <p>Você conseguiu escapar da sala!</p>
                    <p>Todos os desafios foram superados!</p>
                </div>
                <div class="victory-image">
                    <img src="assets/images/vitoria.png" alt="Vitória">
                </div>
            </div>
        </div>

        <!-- TELA DE DERROTA -->
        <div id="defeat-screen" class="screen result-screen">
            <div class="defeat-content">
                <div class="defeat-text">
                    <h1>💀 DERROTA</h1>
                    <p>Você errou a senha...</p>
                    <p>Você nunca vai sair daqui!</p>
                </div>
                <div class="defeat-image">
                    <img src="assets/images/derrota.png" alt="Derrota">
                </div>
            </div>
        </div>
    </div>

    <!-- POPUP DE INPUT PARA SENHA -->
    <div id="password-input-popup" class="password-input-popup">
        <input type="text" id="letter-input" placeholder="Digite uma letra" maxlength="1">
        <div class="input-buttons">
            <button class="confirm-btn" onclick="confirmLetter()">Confirmar</button>
            <button class="cancel-btn" onclick="cancelInput()">Cancelar</button>
        </div>
    </div>

    <!-- BADGE DE PISTAS -->
    <div class="hint-badge" id="hint-badge" style="display: none;" onclick="showHints()">
        💡 Pistas Desbloqueadas
    </div>

    <script>
        // ==================== CONFIGURAÇÕES DO JOGO ====================
        const FINAL_PASSWORD = 'AMORA';
        const gameState = {
            currentScreen: 'tela-inicial',
            currentQuestion: 0,
            currentLevel: 0,
            correctAnswers: 0,
            levelCorrectAnswers: 0,
            timerInterval: null,
            timeRemaining: 60,
            passwordBoxes: ['', '', '', ''],
            hints: [
                { text: 'Uma das letras da senha é a 1ª letra do alfabeto', unlocked: false },
                { text: 'Uma das letras da senha é a 13ª letra do alfabeto', unlocked: false },
                { text: 'Uma das letras da senha aparece duas vezes', unlocked: false },
                { text: 'Existem apenas 2 vogais diferentes nessa senha', unlocked: false },
                { text: 'É O NOME DE UMA FRUTA', unlocked: false }
            ]
        };

        // ==================== QUESTÕES DO JOGO ====================
        const questions = [
            // NÍVEL 1 - FÁCIL (Questões 1-5)
            {
                level: 1,
                text: 'Se você tem 3 maçãs e ganha mais 2, quantas maçãs tem no total?',
                answers: ['A) 4', 'B) 5', 'C) 6', 'D) 7', 'E) 8'],
                correct: 1
            },
            {
                level: 1,
                text: 'Qual é o dobro de 6?',
                answers: ['A) 10', 'B) 11', 'C) 12', 'D) 13', 'E) 14'],
                correct: 2
            },
            {
                level: 1,
                text: 'Se você tem 10 reais e gasta 3, quanto sobra?',
                answers: ['A) 5', 'B) 6', 'C) 7', 'D) 8', 'E) 9'],
                correct: 2
            },
            {
                level: 1,
                text: 'Qual número vem depois do 7?',
                answers: ['A) 5', 'B) 6', 'C) 8', 'D) 9', 'E) 10'],
                correct: 2
            },
            {
                level: 1,
                text: 'Quanto é 5 + 5?',
                answers: ['A) 8', 'B) 9', 'C) 10', 'D) 11', 'E) 12'],
                correct: 2
            },

            // NÍVEL 2 - MÉDIO (Questões 6-10)
            {
                level: 2,
                text: 'Se uma caixa tem 12 ovos e você quebra 3, quantos ficam inteiros?',
                answers: ['A) 8', 'B) 9', 'C) 10', 'D) 11', 'E) 12'],
                correct: 2
            },
            {
                level: 2,
                text: 'Qual é a metade de 20?',
                answers: ['A) 5', 'B) 8', 'C) 10', 'D) 15', 'E) 20'],
                correct: 2
            },
            {
                level: 2,
                text: 'Se você tem 4 grupos com 3 pessoas cada, quantas pessoas tem no total?',
                answers: ['A) 7', 'B) 10', 'C) 12', 'D) 15', 'E) 16'],
                correct: 2
            },
            {
                level: 2,
                text: 'Quanto é 15 - 7?',
                answers: ['A) 6', 'B) 7', 'C) 8', 'D) 9', 'E) 10'],
                correct: 2
            },
            {
                level: 2,
                text: 'Se um livro custa 25 reais e você ganha 10 reais de desconto, quanto paga?',
                answers: ['A) 10', 'B) 12', 'C) 15', 'D) 18', 'E) 20'],
                correct: 3
            },

            // NÍVEL 3 - INTERMEDIÁRIO (Questões 11-15)
            {
                level: 3,
                text: 'Uma pessoa trabalha 8 horas por dia. Em 5 dias, quantas horas trabalha?',
                answers: ['A) 30', 'B) 35', 'C) 40', 'D) 45', 'E) 50'],
                correct: 2
            },
            {
                level: 3,
                text: 'Se você tem 100 reais e gasta 35, quanto sobra?',
                answers: ['A) 55', 'B) 60', 'C) 65', 'D) 70', 'E) 75'],
                correct: 2
            },
            {
                level: 3,
                text: 'Qual é o resultado de 7 x 8?',
                answers: ['A) 52', 'B) 54', 'C) 56', 'D) 58', 'E) 60'],
                correct: 2
            },
            {
                level: 3,
                text: 'Se você tem 60 frutas e divide em 3 grupos iguais, cada grupo tem quantas frutas?',
                answers: ['A) 15', 'B) 18', 'C) 20', 'D) 22', 'E) 25'],
                correct: 2
            },
            {
                level: 3,
                text: 'Quanto é 45 + 27?',
                answers: ['A) 62', 'B) 65', 'C) 70', 'D) 72', 'E) 75'],
                correct: 3
            },

            // NÍVEL 4 - DIFÍCIL (Questões 16-20)
            {
                level: 4,
                text: 'Uma loja vende 12 produtos por dia. Em 30 dias, quantos produtos vende?',
                answers: ['A) 300', 'B) 320', 'C) 340', 'D) 360', 'E) 380'],
                correct: 3
            },
            {
                level: 4,
                text: 'Se você tem 250 reais e gasta 3/5 dessa quantia, quanto sobra?',
                answers: ['A) 50', 'B) 75', 'C) 100', 'D) 125', 'E) 150'],
                correct: 4
            },
            {
                level: 4,
                text: 'Qual é o resultado de 123 + 456?',
                answers: ['A) 555', 'B) 575', 'C) 579', 'D) 589', 'E) 599'],
                correct: 3
            },
            {
                level: 4,
                text: 'Se uma máquina produz 45 peças por hora, quantas produz em 8 horas?',
                answers: ['A) 320', 'B) 340', 'C) 360', 'D) 380', 'E) 400'],
                correct: 2
            },
            {
                level: 4,
                text: 'Quanto é 89 - 34?',
                answers: ['A) 45', 'B) 50', 'C) 55', 'D) 60', 'E) 65'],
                correct: 2
            },

            // NÍVEL 5 - MUITO DIFÍCIL (Questões 21-25)
            {
                level: 5,
                text: 'Se uma árvore cresce 2,5 metros por ano, quanto cresce em 4 anos?',
                answers: ['A) 8 metros', 'B) 9 metros', 'C) 10 metros', 'D) 11 metros', 'E) 12 metros'],
                correct: 2
            },
            {
                level: 5,
                text: 'Uma empresa tem 500 funcionários. Se 40% saem de férias, quantos continuam trabalhando?',
                answers: ['A) 200', 'B) 250', 'C) 300', 'D) 350', 'E) 400'],
                correct: 3
            },
            {
                level: 5,
                text: 'Qual é o resultado de 1234 + 5678 - 2000?',
                answers: ['A) 4512', 'B) 4712', 'C) 4912', 'D) 5112', 'E) 5312'],
                correct: 3
            },
            {
                level: 5,
                text: 'Se você tem 1000 reais e ganha 15% de juros, quanto tem agora?',
                answers: ['A) 1100', 'B) 1150', 'C) 1200', 'D) 1250', 'E) 1300'],
                correct: 1
            },
            {
                level: 5,
                text: 'Uma piscina tem 2400 litros. Se drena 1/3 da água, quantos litros sobram?',
                answers: ['A) 800', 'B) 1200', 'C) 1400', 'D) 1600', 'E) 1800'],
                correct: 4
            }
        ];

        // ==================== FUNÇÕES DE NAVEGAÇÃO ====================
        function showScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
            gameState.currentScreen = screenId;
        }

        function startNarrative() {
            showScreen('narrativa-1');
            playSound('musica');
        }

        function nextScreen() {
            const currentNum = parseInt(gameState.currentScreen.split('-')[1]);
            const nextNum = currentNum + 1;
            if (nextNum <= 7) {
                showScreen(`narrativa-${nextNum}`);
            } else {
                startQuestions();
            }
        }

        function startQuestions() {
            gameState.currentQuestion = 0;
            gameState.currentLevel = 0;
            gameState.correctAnswers = 0;
            gameState.levelCorrectAnswers = 0;
            loadQuestion();
            showScreen('question-screen');
        }

        function loadQuestion() {
            const question = questions[gameState.currentQuestion];
            gameState.currentLevel = question.level;
            const levelNames = ['', 'Fácil', 'Médio', 'Intermediário', 'Difícil', 'Muito Difícil'];

            document.getElementById('current-question').textContent = gameState.currentQuestion + 1;
            document.getElementById('current-level').textContent = levelNames[question.level];
            document.getElementById('question-text').textContent = question.text;

            const answersContainer = document.getElementById('answers-container');
            answersContainer.innerHTML = '';
            question.answers.forEach((answer, index) => {
                const btn = document.createElement('button');
                btn.className = 'answer-btn';
                btn.textContent = answer;
                btn.onclick = () => selectAnswer(index, question.correct);
                answersContainer.appendChild(btn);
            });

            startTimer();
        }

        function selectAnswer(selectedIndex, correctIndex) {
            clearInterval(gameState.timerInterval);
            const answerBtns = document.querySelectorAll('.answer-btn');
            answerBtns.forEach(btn => btn.disabled = true);

            if (selectedIndex === correctIndex) {
                answerBtns[selectedIndex].classList.add('correct');
                gameState.correctAnswers++;
                gameState.levelCorrectAnswers++;
                playSound('acerto');
                setTimeout(() => {
                    showScreen('correct-result');
                    setTimeout(() => {
                        nextQuestion();
                    }, 2000);
                }, 500);
            } else {
                answerBtns[selectedIndex].classList.add('incorrect');
                answerBtns[correctIndex].classList.add('correct');
                playSound('erro');
                document.getElementById('correct-answer').textContent = 
                    questions[gameState.currentQuestion].answers[correctIndex];
                setTimeout(() => {
                    showScreen('incorrect-result');
                    setTimeout(() => {
                        nextQuestion();
                    }, 2000);
                }, 500);
            }
        }

        function nextQuestion() {
            // Verificar se completou um nível
            if ((gameState.currentQuestion + 1) % 5 === 0) {
                if (gameState.levelCorrectAnswers >= 4) {
                    // Desbloquear pista do nível
                    const levelIndex = gameState.currentLevel - 1;
                    if (levelIndex < gameState.hints.length) {
                        gameState.hints[levelIndex].unlocked = true;
                    }
                    checkUnlockedHints();
                }
                gameState.levelCorrectAnswers = 0;
            }

            gameState.currentQuestion++;
            if (gameState.currentQuestion < 25) {
                loadQuestion();
                showScreen('question-screen');
            } else {
                // Desafio final
                initializeFinalChallenge();
                showScreen('final-challenge');
            }
        }

        function startTimer() {
            gameState.timeRemaining = 60;
            updateTimerDisplay();

            gameState.timerInterval = setInterval(() => {
                gameState.timeRemaining--;
                updateTimerDisplay();

                if (gameState.timeRemaining === 0) {
                    clearInterval(gameState.timerInterval);
                    handleTimeout();
                } else if (gameState.timeRemaining <= 10) {
                    playSound('cronometro');
                    document.getElementById('timer').classList.add('warning');
                }
            }, 1000);
        }

        function updateTimerDisplay() {
            const minutes = Math.floor(gameState.timeRemaining / 60);
            const seconds = gameState.timeRemaining % 60;
            document.getElementById('timer').textContent = 
                `${minutes}:${seconds.toString().padStart(2, '0')}`;
        }

        function handleTimeout() {
            const answerBtns = document.querySelectorAll('.answer-btn');
            answerBtns.forEach(btn => btn.disabled = true);
            document.getElementById('timer').classList.remove('warning');
            
            playSound('tempo-esgotado');
            showScreen('timeout-screen');
            
            setTimeout(() => {
                nextQuestion();
            }, 3000);
        }

        // ==================== DESAFIO FINAL ====================
        function initializeFinalChallenge() {
            const boxesContainer = document.getElementById('password-boxes');
            boxesContainer.innerHTML = '';
            gameState.passwordBoxes = ['', '', '', ''];

            for (let i = 0; i < 4; i++) {
                const box = document.createElement('div');
                box.className = 'password-box';
                box.textContent = '';
                box.onclick = () => openLetterInput(i);
                boxesContainer.appendChild(box);
            }
        }

        function openLetterInput(position) {
            const popup = document.getElementById('password-input-popup');
            popup.classList.add('active');
            document.getElementById('letter-input').value = gameState.passwordBoxes[position] || '';
            document.getElementById('letter-input').focus();
            document.getElementById('letter-input').dataset.position = position;

            document.getElementById('letter-input').onkeypress = (e) => {
                if (e.key === 'Enter') {
                    confirmLetter();
                }
            };
        }

        function confirmLetter() {
            const input = document.getElementById('letter-input');
            const position = parseInt(input.dataset.position);
            let letter = input.value.toUpperCase();

            if (letter && letter.match(/[A-Z]/)) {
                gameState.passwordBoxes[position] = letter;
                const boxes = document.querySelectorAll('.password-box');
                boxes[position].textContent = letter;
                cancelInput();
            }
        }

        function cancelInput() {
            const popup = document.getElementById('password-input-popup');
            popup.classList.remove('active');
            document.getElementById('letter-input').value = '';
        }

        function submitPassword() {
            const enteredPassword = gameState.passwordBoxes.join('');
            
            if (enteredPassword.length < 4) {
                alert('Complete todas as letras da senha!');
                return;
            }

            if (enteredPassword === FINAL_PASSWORD) {
                playSound('vitoria');
                showScreen('victory-screen');
            } else {
                playSound('derrota');
                showScreen('defeat-screen');
            }
        }

        // ==================== PISTAS ====================
        function checkUnlockedHints() {
            const unlockedCount = gameState.hints.filter(h => h.unlocked).length;
            const badge = document.getElementById('hint-badge');
            
            if (unlockedCount > 0) {
                badge.style.display = 'block';
                badge.textContent = `💡 ${unlockedCount} Pista${unlockedCount > 1 ? 's' : ''} Desbloqueada${unlockedCount > 1 ? 's' : ''}`;
            }
        }

        function showHints() {
            const hintsList = document.getElementById('hints-list');
            hintsList.innerHTML = '';

            gameState.hints.forEach((hint, index) => {
                const hintDiv = document.createElement('div');
                hintDiv.className = `hint-item ${!hint.unlocked ? 'locked' : ''}`;
                hintDiv.innerHTML = `<strong>Pista ${index + 1}:</strong> ${hint.unlocked ? hint.text : '🔒 Bloqueada'}`;
                hintsList.appendChild(hintDiv);
            });

            showScreen('hints-screen');
        }

        function closeHints() {
            showScreen(gameState.currentScreen);
        }

        // ==================== SONS ====================
        function playSound(soundName) {
            const audioMap = {
                'musica': 'assets/sounds/musica.mp3',
                'erro': 'assets/sounds/erro.mp3',
                'acerto': 'assets/sounds/acerto.mp3',
                'tempo-esgotado': 'assets/sounds/tempo-esgotado.mp3',
                'cronometro': 'assets/sounds/cronometro.mp3',
                'vitoria': 'assets/sounds/vitoria.mp3',
                'derrota': 'assets/sounds/derrota.mp3'
            };

            const audioUrl = audioMap[soundName];
            if (audioUrl) {
                const audio = new Audio(audioUrl);
                audio.play().catch(e => console.log('Erro ao reproduzir som:', e));
            }
        }

        // ==================== TELA CHEIA ====================
        document.getElementById('fullscreenBtn').addEventListener('click', () => {
            const elem = document.documentElement;
            if (elem.requestFullscreen) {
                elem.requestFullscreen();
            } else if (elem.webkitRequestFullscreen) {
                elem.webkitRequestFullscreen();
            } else if (elem.mozRequestFullScreen) {
                elem.mozRequestFullScreen();
            } else if (elem.msRequestFullscreen) {
                elem.msRequestFullscreen();
            }
        });

        // ==================== PWA - SERVICE WORKER ====================
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('service-worker.js').catch(e => console.log('SW não registrado:', e));
        }
    </script>
</body>
</html>
